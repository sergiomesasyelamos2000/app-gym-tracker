{
  "expo": {
    "name": "EvoFit",
    "slug": "app",
    "platforms": ["ios", "android", "web"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": [
      "com.smy862.app",
      "com.googleusercontent.apps.1029378599483-55i89a23olo9k8pvidrveh2pkfn1cuni"
    ],
    "notification": {
      "icon": "./assets/icon.png"
    },
    "ios": {
      "icon": "./assets/ios-icon.png",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.smy862.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "NSPhotoLibraryUsageDescription": "EvoFit necesita acceso a tu fototeca para que puedas elegir una imagen de perfil o subir una foto de comida para analizarla y registrarla en tu diario nutricional.",
        "NSCameraUsageDescription": "EvoFit necesita acceso a la cámara para que puedas hacer fotos de comidas y registrarlas en tu seguimiento nutricional.",
        "NSMicrophoneUsageDescription": "EvoFit solicita acceso al micrófono solo cuando grabas contenido multimedia que lo requiera dentro de la app."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B21B6"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.smy862.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1029378599483-9b2ho2kkigj6foqvjuji2lslunvrm3bv"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "EvoFit necesita acceso a la camara para que puedas hacer fotos de comidas y registrarlas en tu seguimiento nutricional.",
          "microphonePermission": "EvoFit solicita acceso al microfono solo cuando grabas contenido multimedia que lo requiera dentro de la app.",
          "recordAudioAndroid": true
        }
      ],
      "./plugins/withRestTimerLiveActivity",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "59890898-088b-402b-bc22-b15ec51d1c17"
      }
    },
    "owner": "smy862"
  }
}
