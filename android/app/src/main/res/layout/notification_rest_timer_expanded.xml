<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:paddingStart="12dp"
  android:paddingTop="12dp"
  android:paddingEnd="12dp"
  android:paddingBottom="12dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/rest_timer_exercise_image"
      android:layout_width="52dp"
      android:layout_height="52dp"
      android:layout_marginEnd="12dp"
      android:background="@drawable/rest_timer_image_bg"
      android:scaleType="centerCrop" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/rest_timer_exercise_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/rest_timer_next_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#B8FFFFFF"
        android:textSize="12sp" />
    </LinearLayout>

    <Chronometer
      android:id="@+id/rest_timer_time"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="12dp"
      android:format="%s"
      android:textColor="#8F59FF"
      android:textSize="28sp"
      android:textStyle="bold" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/rest_timer_minus"
      android:layout_width="0dp"
      android:layout_height="40dp"
      android:layout_marginEnd="6dp"
      android:layout_weight="1"
      android:background="@drawable/rest_timer_button_secondary"
      android:gravity="center"
      android:text="-15s"
      android:textColor="@android:color/white"
      android:textSize="13sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/rest_timer_plus"
      android:layout_width="0dp"
      android:layout_height="40dp"
      android:layout_marginEnd="6dp"
      android:layout_weight="1"
      android:background="@drawable/rest_timer_button_primary"
      android:gravity="center"
      android:text="+15s"
      android:textColor="@android:color/white"
      android:textSize="13sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/rest_timer_skip"
      android:layout_width="0dp"
      android:layout_height="40dp"
      android:layout_weight="1"
      android:background="@drawable/rest_timer_button_danger"
      android:gravity="center"
      android:text="Omitir"
      android:textColor="@android:color/white"
      android:textSize="13sp"
      android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
