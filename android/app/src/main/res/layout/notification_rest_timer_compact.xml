<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:gravity="center_vertical"
  android:minHeight="64dp"
  android:orientation="horizontal"
  android:paddingStart="12dp"
  android:paddingTop="10dp"
  android:paddingEnd="12dp"
  android:paddingBottom="10dp">

  <ImageView
    android:id="@+id/rest_timer_exercise_image"
    android:layout_width="44dp"
    android:layout_height="44dp"
    android:layout_marginEnd="12dp"
    android:background="@drawable/rest_timer_image_bg"
    android:scaleType="centerCrop" />

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
      android:id="@+id/rest_timer_exercise_name"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@android:color/white"
      android:textSize="15sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/rest_timer_next_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="#B8FFFFFF"
      android:textSize="12sp" />
  </LinearLayout>

  <Chronometer
    android:id="@+id/rest_timer_time"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:format="%s"
    android:textColor="#8F59FF"
    android:textSize="24sp"
    android:textStyle="bold" />
</LinearLayout>
